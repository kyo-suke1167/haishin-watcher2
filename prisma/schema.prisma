// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 🎯 監視対象の配信（Video IDなどを保存）
model ChannelTarget {
  id              String   @id @default(cuid())
  channelId       String   @unique
  name            String
  thumbnail       String?
  isRecordEnabled Boolean  @default(false) // リアルタイム録音フラグ
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt // 🌟 既存データのために @default(now()) を追加！
}

model StreamTarget {
  id           String   @id @default(cuid())
  videoId      String   @unique
  title        String?
  status       String   @default("waiting")
  recordingPid Int?     // バックグラウンド録音プロセスのID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt // 🌟 ここにも追加！
}
